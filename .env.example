# Required: your Claude API key (server-side only, never exposed to the browser)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Optional: enable update emails. Without these, signups are still stored,
# but no emails are sent (the scheduled run just logs them).
RESEND_API_KEY=
FROM_EMAIL=trend-radar@imc.unisg.ch
